# --- Database ---
# Local (docker-compose, fully-offline dev):
# DATABASE_URL=postgres://grid:grid@localhost:5432/grid
# Supabase (project "Grid", ref ukczzbamgfqyvnrlojsc, eu-central-1) — pooled connection,
# get the real password from the Supabase dashboard (Project Settings -> Database):
DATABASE_URL=postgres://postgres.ukczzbamgfqyvnrlojsc:[DB_PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# --- Redis (presence, rate limiting, time-windowed usage caps) ---
# Local (docker-compose): redis://localhost:6379
# Render Key Value: copy the "Internal Redis URL" or "External Redis URL" from the Render dashboard
REDIS_URL=redis://localhost:6379

# --- Auth ---
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too

# --- Media storage (S3-compatible) ---
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# --- Web Push (VAPID) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- Phase 0 stub flags (see PRD §10/§12 step 3) ---
# stub  = manual admin flag only, no vendor call (Phase 0 — Internal Alpha)
# vendor = real vendor integration (Phase 1 — Pre-Launch Delivery)
AGE_VERIFICATION_MODE=stub
PAYMENTS_MODE=stub

# --- API ---
PORT=3000
